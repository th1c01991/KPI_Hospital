@usuarioFernanda = d5dd92b8-2453-4005-ad16-1c18e945c7d2
@setorUtiAdulto = 5351b43b-3379-4996-b547-ca8035a4c2b0

@indicadorTxIPCS = 2a1fffd1-282b-42f1-b2a2-ffbf0f090579

@metaSetorTxIPCS = f9fb8963-10a1-4a6b-a7a7-f5b3c3378c0f

